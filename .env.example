# IZYLO - Configurações de Ambiente
# Copie este arquivo para .env e preencha os valores

# OBRIGATÓRIO: Chave da API Anthropic (para análise de fotos com IA)
# Crie sua chave em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# Chave secreta para JWT (mude para algo único e seguro em produção!)
SECRET_KEY=izylo-mude-esta-chave-em-producao-2024

# Porta do servidor (padrão: 8888)
PORT=8888

# Google OAuth (login com Google)
# Obtenha em https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI deve ser: <APP_BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
